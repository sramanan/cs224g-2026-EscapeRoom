# ──────────────────────────────────────────────────────────────────
# The Puzzle Master's Escape Room — environment config
# ──────────────────────────────────────────────────────────────────
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env — it is in .gitignore
# ──────────────────────────────────────────────────────────────────

# ─── Required ─────────────────────────────────────────────────────

# OpenAI API key for the Realtime API (client_secrets, realtime/calls)
# Create at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ─── Optional ────────────────────────────────────────────────────

# Custom API base URL (e.g. Azure OpenAI, proxy, or local mock)
# Omit to use https://api.openai.com
# OPENAI_BASE_URL=https://api.openai.com

# Organization ID for multi-account setups
# OPENAI_ORG_ID=org-xxx
